        "2493": {
          "vnum": 2493,
          "name": "Cavern of Strange Stones",
          "description": "The uneven dirt beneath your feet, littered with sections of cloth and bits of grass, extends to the north and west beneath the vast orange dome of the cavern. The glare of the light at times makes it difficult to distinguish the motionless striders from the odd stone figures that never move.",
