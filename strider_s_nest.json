        "3051": {
          "vnum": 3051,
          "name": "Hidden Chamber",
          "description": "The glow of the previous cavern is noticeably lacking in this small cave, but the same debris of stones covers the floor. No exits are visible other than the passage to the west, through which you entered, but you discern a slow drip of water somewhere in the room.",
