        "2498": {
          "vnum": 2498,
          "name": "Rock-Strewn Cavern",
          "description": "The yellow light from the ceiling of this cavern casts the stones that surround you into sharp contrast, with bright faces touching on black shadows. A few feet from the wall, nestled between two boulders, you find a hole leading down into the darkness. The cavern continues to the east and to the north.",
          "grid_x": 0,
          "grid_y": 19,
          "exits": {
            "w": {
              "to_vnum": 2475,
              "to_zone": "Coastal Ruins - City of Mareldja",
              "to_room_name": "Cramped Passage",
              "direction": "w",
              "is_cross_zone": true,
              "is_portal": false
            }
          },
          "npcs": []
        },
        "3049": {
          "vnum": 3049,
          "name": "Rock-Strewn Cavern",
          "description": "The large boulders scattered about the floor of this cavern dance menacingly at the corners of your vision. When you turn to face them, they cease, basking in the yellowish glow that suffuses the cavern from above. The faces of rock that block progress to the north and east are streaked with crevices. The cavern continues around the stones to the west and south.",
          "grid_x": 1,
          "grid_y": 18,
          "exits": {
