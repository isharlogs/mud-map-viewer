          "npcs": []
        },
        "3050": {
          "vnum": 3050,
          "name": "Rock-Strewn Cavern",
          "description": "A faint yellow glow emanates from the roof of this cavern, illuminating the surrounding area. The brown stone floor is littered with boulders both large and small. The cavern continues to the north and west, while walls rise to block further progress to the east and south. Deep shadows from the massive stones obscure the eastern wall.",
          "grid_x": 1,
          "grid_y": 19,
          "exits": {
