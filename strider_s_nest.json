        "2492": {
          "vnum": 2492,
          "name": "Cavern of Strange Stones",
          "description": "A faint mist threads a path between the grotesque stone forms around you, cast into sparkling dust by the sharp orange light. The floor of the cavern is uneven, and you notice bits of dried grass and cloth poking out in places. The cavern continues to the west and south.",
          "grid_x": -2,
