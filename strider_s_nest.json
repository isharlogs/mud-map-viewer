        "3063": {
          "vnum": 3063,
          "name": "Cavern of Strange Stones",
          "description": "You stand in the southwest corner of the cavern, gazing out across the misshapen stone figures and the striders guarding their nests to the narrow passage leading out of this section. The cavern opens out to the north and east, while to the south and west rise steep stone walls.",
