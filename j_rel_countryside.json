        "757": {
          "vnum": 757,
          "name": "Southern Reaches of the Plain",
          "description": "The hill to the north rises more steeply than you had perceived from afar, obscuring your view of the plain temporarily. The land to the south becomes decidedly marshy and a comically eerie mist seeps out over it, seemingly from within. If you hear a wolf howl from that direction, you'll almost certainly offend it with laughter.",
          "grid_x": -3,
          "grid_y": 1,
          "exits": {
