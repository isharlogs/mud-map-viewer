        "637": {
          "vnum": 637,
          "name": "Approaching an Encampment",
          "description": "The mountain looms large now, rising abruptly from the plain into a layer of fog and out of sight. Just ahead to the north, a small encampment seems to cower in its shadow. Just off the trail, a small patch of land is delicately fenced off.",
          "grid_x": -3,
