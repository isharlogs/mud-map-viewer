        "635": {
          "vnum": 635,
          "name": "Along a Game Trail",
          "description": "Unseen shapes skitter into undergrowth at your approach. The area around you is all low rolling hills, perfect habitat for the multitude of small animals living here, and the larger ones that hunt them.",
          "grid_x": -1,
          "grid_y": -3,
          "exits": {
