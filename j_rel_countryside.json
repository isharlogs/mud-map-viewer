        "634": {
          "vnum": 634,
          "name": "Bend at the Pond",
          "description": "A shallow depression in the land creates a still pond here, only a trickle of water keeping it from stagnancy. Small birds rest and refresh themselves and you feel you might do the same. The trail diverges sharply from the brook here, heading purposefully to the west, while thickening underbrush does little to obscure the rockier hills distantly to the north.",
          "grid_x": -1,
          "grid_y": -2,
          "exits": {
