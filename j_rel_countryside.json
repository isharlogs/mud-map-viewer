          },
          "npcs": [
            {
              "name": "Lone chaplain",
              "description": "as if conferring with the dead.  A hood pulled low gives his thin frame and narrow face an aura of unboastful power.",
              "unique": true
            }
          ]
        },
        "639": {
          "vnum": 639,
          "name": "Miner's Camp",
          "description": "A couple dozen shacks with sod roofs which slope to the ground are arranged in a circle here. To the west a trail leads to the mountain which rises abruptly from the grassy plain and into a white mist which hangs low over the camp. Dust-covered miners go between the camp and the mountain, their faces eerily expressionless as if in deep concentration.",
