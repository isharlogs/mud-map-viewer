        },
        "1999": {
          "vnum": 1999,
          "name": "Torture Chamber",
          "description": "This room, once a place of great security, has been converted into a ghastly torture chamber. Bodies that have suffered all manner of imaginable atrocities messy heaps. The smell is unbearable, almost bringing you to your knees, as if the sight alone wasn't enough. A large, burning crest flanked by the corpses of two men hung by their toes, covers the far wall.",
          "grid_x": 1,
          "grid_y": 0,
