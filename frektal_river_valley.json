              "is_cross_zone": false,
              "is_portal": false
            }
          },
          "npcs": []
        },
        "610": {
          "vnum": 610,
          "name": "A Makeshift Observatory",
          "description": "This room, however, looks entirely lived in. A messy desk at one end of the slope-roofed room bears a lantern of red glass giving off the only light: a dim ruby glow. Books are piled all around and drawings and charts are pinned to every wall. Most strange, of course, is a tree-trunk sized bronze pipe that rises through an elaborate pivoting system at the roof.",
          "grid_x": 0,
          "grid_y": 48,
          "exits": {
            "d": {
              "to_vnum": 609,
              "to_zone": "Frektal River Valley",
              "to_room_name": "Inside the Farmhouse",
              "direction": "d",
              "is_cross_zone": false,
              "is_portal": true
            }
          },
          "npcs": [
            {
              "name": "Galan Uralis",
              "description": "has paled and softened in his darkened observatory.  A glow of satisfaction in his work suffuses him and it is plain that he now lives on",
              "unique": true
            }
          ]
        },
        "612": {
          "vnum": 612,
          "name": "The Junkpit",
          "description": "You descend by way of a steep trail into a large pit which seems to be the result of the ground collapsing into an underground pool. It now seems to be used for the disposal of the town's garbage, and the scent of stagnant water and moist earth mixed with old rubbish repulses you.",
