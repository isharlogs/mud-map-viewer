        "608": {
          "vnum": 608,
          "name": "An Unkempt Poonk Field",
          "description": "Tromping through the field is made even more difficult by the undergrowth which has buried any previous trail and threatens to strangle the ailing crop. You didn't think it possible, but the wilting poonk here smells even worse than if it were well-kept. Nausea overtakes you in rolling waves.",
          "grid_x": -6,
          "grid_y": 3,
          "exits": {
            "w": {
