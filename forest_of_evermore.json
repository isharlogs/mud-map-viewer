        "3085": {
          "vnum": 3085,
          "name": "A Submerged Tunnel",
          "description": "As you paddle in the dark tunnel you feel the pull of the current urging you northward. You are careful not to veer too close to any of the walls as jagged rocks protrude throughout the tunnel. A strange, cold, pulsing chills you to the bone.",
          "grid_x": 0,
          "grid_y": 0,
          "exits": {
            "u": {
              "to_vnum": 3086,
              "to_zone": "Forest of Evermore",
              "to_room_name": "An Opaque Pool",
              "direction": "u",
              "is_cross_zone": false,
              "is_portal": true
            }
          },
          "npcs": [
            {
              "name": "Kial",
              "description": "Having seen the world in ages long past, Kial is an ancient shadow that practices arts unseen by man for eons. Looking into your eyes his gaze pierces into you, passing judgment upon your soul.",
              "unique": true
            }
          ]
        }
      },
