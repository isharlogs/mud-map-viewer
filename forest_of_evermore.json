        "3083": {
          "vnum": 3083,
          "name": "Path Through a Shrouded Dell",
          "description": "The pines start to thin as you near the center of the dell. Long shadows are cast by the towering pines enveloping you in a shroud of black. Birds in the distance call out to one another in strange melodies.",
