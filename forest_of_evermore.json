          "npcs": [
            {
              "name": "Wolverine",
              "description": "Ready to pounce upon its prey at any moment, a wolverine flashes an evil grin. A wolverine looks like an enormous weasel; it is a stocky, dark-furred, bushy tailed creature that has an enormous appetite.",
              "unique": true
            }
          ]
