        "3078": {
          "vnum": 3078,
          "name": "The Forest of Evermore",
          "description": "The pines continue on and the surrounding foliage flourishes. Animal calls are heard from every quarter of the wood within earshot. The forest teems with life all around you, a sanctuary obviously protected by the gods.",
