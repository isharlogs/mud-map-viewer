        "1761": {
          "vnum": 1761,
          "name": "Over the Mages Guild",
          "description": "You stand upon the roof of the Purple Flame. Below, you can see where the Avenue of Eternity joins with the Painters' Boulevard. People pass you below, oblivious to your presence. To the east over an alley is the flat roof of a merchant's house.",
          "grid_x": 3,
          "grid_y": 1,
          "exits": {
