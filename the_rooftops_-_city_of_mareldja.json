        "1763": {
          "vnum": 1763,
          "name": "Over the Gate of Earth",
          "description": "The Concourse of Earth passes beneath you, a cobbled road worn somewhat smooth by the passage of many feet. As it leaves the city, the cobblestones cease and are replaced by simple dirt. A steady breeze greets you, and the sky is a deep blue. The wall runs to the north and south.",
          "grid_x": 0,
          "grid_y": 1,
