        "1758": {
          "vnum": 1758,
          "name": "Over the Golden Vanity",
          "description": "The Golden Vanity does not look like much from up here. A wooden sign dangles from the doorway with a picture of a ship and the name of the establishment. A window on the second floor peers out over the street. Pigeons nest up here for free, never having to pay a penny.",
