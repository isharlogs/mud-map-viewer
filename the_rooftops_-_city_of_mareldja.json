        "1310": {
          "vnum": 1310,
          "name": "Over Farath`s Armory",
          "description": "Smoke rises from a sooty chimney, and you can hear clanking coming from the inside. If you were to peek in a window, you could probably see Farath at work. Roofs to the east and north allow you to continue your aerial journey.",
