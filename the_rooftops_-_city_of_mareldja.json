        "1762": {
          "vnum": 1762,
          "name": "City Wall",
          "description": "The wall is crenelated and swept free of dirt and debris. Gazing out over it, you can see the Forest of Jharet spread over the land like a cloak, its majestic folds covering the bones of the cliff. Just to the south you can walk over the Gate of Earth. A building built against the wall also allows you to climb down.",
          "grid_x": 0,
          "grid_y": 0,
          "exits": {
            "s": {
              "to_vnum": 1763,
