        "1769": {
          "vnum": 1769,
          "name": "On the Rooftops",
          "description": "Leaping from roof to roof, you discover that a whole new world exists up here. Freedom of movement is both extended and restricted. There are no crowds to deal with, but your choice of directions is limited to those buildings immediately next to you. From here you can travel north and south.",
