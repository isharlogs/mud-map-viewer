          "npcs": []
        },
        "1348": {
          "vnum": 1348,
          "name": "Forest Path",
          "description": "Through the great old trees this thin path twists, traveling further south. The sound of rumbling water becomes louder as you progress.",
          "grid_x": 0,
          "grid_y": 16,
          "exits": {
            "n": {
              "to_vnum": 1347,
              "to_zone": "Central Forest - Jharet Forest",
              "to_room_name": "Forest Path",
