        "3602": {
          "vnum": 3602,
          "name": "On the Cliff",
          "description": "You cling to the side of a inwardly sloping cliff above the river of Bruenor's Woe. Below the water flows idly by, through the canyon, awaiting your splashing form should you slip. Here a small cave entrance beckons, appearing a much safer exit than the precarious climb back down the cliff.",
          "grid_x": 5,
          "grid_y": 30,
          "exits": {
            "go into": {
              "to_vnum": 3603,
