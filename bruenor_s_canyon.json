              "is_portal": true
            }
          },
          "npcs": []
        },
        "3603": {
          "vnum": 3603,
          "name": "Painted Cave",
          "description": "The sound of running water from the river below echoes in this small cave along the cliff. The ceiling lowers deeper into the cave where it splits off in two directions. Upon the moistened walls here are several crude paintings.",
          "grid_x": 0,
          "grid_y": 48,
