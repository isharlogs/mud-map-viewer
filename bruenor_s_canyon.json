              "is_portal": false
            }
          },
          "npcs": []
        },
        "1471": {
          "vnum": 1471,
          "name": "Gorge Bottom",
          "description": "The high walls of granite that define this canyon serve to cool and dim it. A footpath leads up to a road high above, and a narrow wash leads north into an even dimmer section of the place.",
