        "3067": {
          "vnum": 3067,
          "name": "Fields of Corn and Barley",
          "description": "A scarecrow bears silent witness to a man's despair: row after row of sere stalks of corn and blades of barley. It is said that Ishar's blood ran from his chest til it collected as the sea. It is whispered that He might have spared some of this blood for the skies.",
          "grid_x": 1,
          "grid_y": 4,
