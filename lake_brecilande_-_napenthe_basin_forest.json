        "3628": {
          "vnum": 3628,
          "name": "Protected Shore",
          "description": "The verdant foliage of the basin gives way to a serene oasis on the lakeshore. Crystal-clear water laps gently at the edge of the protected area, the vibrant greenery thriving under the watchful presence of shamanic totems. Just beyond the boundary of protection, the dark waters of the lake turn murky and sinister, causing the plant life to wither and decay upon contact. The atmosphere within the oasis is one of tranquility, a stark contrast to the foreboding waters beyond.",
          "grid_x": 0,
          "grid_y": 2,
          "exits": {
