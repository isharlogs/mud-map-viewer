          "npcs": [
            {
              "name": "Merman warrior",
              "description": "The merman of the Black Fin stands tall and proud, his muscular torso and powerful arms rippling with strength. His skin is a deep, midnight blue, marked with intricate tattoos that seem to writhe and twist like living things.",
              "unique": false
