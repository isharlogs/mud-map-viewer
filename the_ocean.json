        "2165": {
          "vnum": 2165,
          "name": "By the Dark Cliff",
          "description": "You are passing along the front of a high, dark cliff which seems to glower down on you. It is featureless and smooth and affords no place to escape the grasp of the sea. The cliff continues to the south.",
