            }
          },
          "npcs": []
        },
        "2161": {
          "vnum": 2161,
          "name": "Forbidding Coast",
          "description": "This stretch of coast offers a rugged allure. Rather than serene, white beaches, forceful swells surge eastward, violently crashing against a chaotic sprawl of jagged rocks. Dominating the eastern perspective is a sturdy wharf, bravely jutting out amidst the relentless waves.",
