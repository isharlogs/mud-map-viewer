        "2160": {
          "vnum": 2160,
          "name": "Watery Death",
          "description": "As you start to enter this narrow channel, you realize you have made a horrendous mistake! The water moves with incredible force and you find yourself helpless against its relentless power. The churning, white water forces its way into your lungs as it carries you faster and faster toward a final union with the jagged rocks ahead!",
          "grid_x": 1,
          "grid_y": 0,
          "exits": {
            "w": {
