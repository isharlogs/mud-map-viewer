        "2166": {
          "vnum": 2166,
          "name": "Muted Waters",
          "description": "The tranquil harbor's waters mirror the muted hues of the sky. To the east, a bustling village unfolds with silhouettes of cottages and market stalls. The scent of saltwater intermingles with distant aromas of village activities.",
