          "npcs": []
        },
        "3148": {
          "vnum": 3148,
          "name": "The Mouth of the River Telemacus",
          "description": "The swift river widens and empties into Lake Arlyn in silent fury. The lands across the river are beautiful compared with the tall, dark trees and dead hills to the north. The lake, at least, brims with life.",
          "grid_x": -2,
          "grid_y": -4,
          "exits": {
