        "2617": {
          "vnum": 2617,
          "name": "The Flowering Hillsides",
          "description": "The hills here seem almost majestic in their purple floral attire. The flowing smoothness of the earth combined with the beauty of the colombine carpet leaves you dumbstruck. The sweet scent of the flowers relaxes you, and you feel safe and comfortable. Occasionally you glimpse the form of a wild mountain goat frolicking about on a nearby hill, but nothing approaches you.",
          "grid_x": -3,
          "grid_y": -1,
          "exits": {
            "e": {
              "to_vnum": 3069,
              "to_zone": "The Hills North of Mareldja",
