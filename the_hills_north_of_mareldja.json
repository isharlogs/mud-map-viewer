            }
          },
          "npcs": [
            {
              "name": "Elf",
              "description": "The elf is dressed in fine green attire, with a longbow slung over his shoulder and a shortsword at his waist.",
              "unique": false
            }
          ]
        },
        "3146": {
          "vnum": 3146,
          "name": "Mouth of the River Telemacus",
          "description": "The swift river widens and empties into Lake Arlyn in silent fury. Several trees grow nearby, their wide trunks scarred with bladed age. The river is here, as elsewhere, uncrossable. Across the lake rise more hills, quite dark despite the sunlight, perhaps covered with trees. The distant roar of a waterfall tickles your ears as you gaze eastward across the lake.",
          "grid_x": -2,
          "grid_y": -3,
          "exits": {
