        "3147": {
          "vnum": 3147,
          "name": "The Southern Shore of Lake Arlyn",
          "description": "A large lake stretches northward from your feet, alive with fish and insects. The far side rolls upward into dark, foreboding hills. To the east, the lake empties down into the valley below in a sparkling roar.",
          "grid_x": -1,
          "grid_y": -3,
          "exits": {
            "w": {
              "to_vnum": 3146,
              "to_zone": "The Hills North of Mareldja",
