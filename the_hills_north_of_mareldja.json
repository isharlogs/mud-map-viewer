        "215": {
          "vnum": 215,
          "name": "Trail North of Mareldja",
          "description": "The trail you travel runs north through the grasslands, paralleling the low stone wall of the cemetery to the east. Beyond the wall, you can see a tower rising among some trees. South of here, the trail joins the Road of Tears, while to the north it bends east around the end of the cemetery wall.",
          "grid_x": -4,
          "grid_y": 2,
          "exits": {
            "n": {
