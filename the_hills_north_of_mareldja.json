        "216": {
          "vnum": 216,
          "name": "Around the Cemetery Wall",
          "description": "Here the trail through the grasses bends from east to south as it wraps itself around the low stone wall of the cemetery. Trees inside the grounds block any view you might have of the tombs and monuments. To the north, the prairies sweep away to the hills and mountains, while to the east the trail continues for a brief stretch to the back of the cemetery.",
          "grid_x": -4,
          "grid_y": 1,
          "exits": {
