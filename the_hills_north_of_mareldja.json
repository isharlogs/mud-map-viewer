        "218": {
          "vnum": 218,
          "name": "The North Boundary of Mareldja",
          "description": "You have reached the edge of civilization. The vast and wild hills sprawl lazily in the sunlight, indifferent to your presence. Clumps of trees dot the hills, and a warm breeze blows southward laden with the soft scent of grass and wildflowers.",
