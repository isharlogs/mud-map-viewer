              "to_zone": "Goblin Lair",
              "to_room_name": "A Narrow and Steep Path",
              "direction": "w",
              "is_cross_zone": true,
              "is_portal": false
            }
          },
          "npcs": [
            {
              "name": "Troll",
              "description": "And you thought it was just a fairy tale, didn't you?  But here's the big ugly thing himself, grey skin, six inch nose, two inch yellow fangs",
              "unique": true
            }
          ]
        },
        "3145": {
          "vnum": 3145,
          "name": "The Hills",
          "description": "The hills here look as if they have been coated with pitch. All that grows here is a stringy black grass that may as well be dead. The only sound is the moaning of the wind as it scrapes the bald peaks.",
          "grid_x": -2,
          "grid_y": -2,
          "exits": {
            "n": {
