          "npcs": []
        },
        "2510": {
          "vnum": 2510,
          "name": "The Northern Shore of Lake Arlyn",
          "description": "Looking out across the shining surface of Lake Arlyn, it is almost easy to forget about the death and destruction that lies behind you, in the hills. Perhaps you should rest here a while before making your way to the lair of the dwarves. (You are riding atop a riding bird.)",
          "grid_x": 0,
