          "npcs": []
        },
        "2508": {
          "vnum": 2508,
          "name": "At the Waterfall",
          "description": "The water smashes down from the heights, alive and heady with power. One step could end your life, but you are not afraid as you stare at the mighty current. A sense of raw power fills your head and you envision the very elements themselves at your fingertips, whimsically tearing lightning from the heavens and sending it crashing to the earth below. But then, it will take a long time before you can even light a candle with your magic... (You are riding atop a riding bird.)",
          "grid_x": 0,
          "grid_y": -2,
          "exits": {
            "n": {
              "to_vnum": 2509,
              "to_zone": "The Hills North of Mareldja",
              "to_room_name": "The Eastern Shore of Lake Arlyn",
              "direction": "n",
              "is_cross_zone": false,
              "is_portal": false
            }
          },
          "npcs": [
            {
              "name": "Bright red beetle",
              "description": "The beetle's carapace is a uniform bright red in color, the color of fresh blood.  Is that a human hand it's carrying in those mandibles?!?",
              "unique": false
            }
          ]
        },
        "2509": {
          "vnum": 2509,
          "name": "The Eastern Shore of Lake Arlyn",
          "description": "The shore here is quite narrow, and the contrast is great. Westward is Lake Arlyn, where fish gather in large groups and play merrily beneath the waves. East and north are hills charred by the curse of the mountain dwarves. The hills directly north are unclimbable, but a path leads around to the north shore. (You are riding atop a riding bird.)",
          "grid_x": 0,
          "grid_y": -3,
          "exits": {
            "n": {
              "to_vnum": 2510,
              "to_zone": "The Hills North of Mareldja",
              "to_room_name": "The Northern Shore of Lake Arlyn",
              "direction": "n",
