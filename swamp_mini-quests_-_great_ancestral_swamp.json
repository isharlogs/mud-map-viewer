            }
          },
          "npcs": []
        },
        "783": {
          "vnum": 783,
          "name": "Inside a Bone Hut",
          "description": "The hut is sparsely decorated with a half dozen large egg shells, five mashed helmets, four old heads, two new ones and tens of skulls. A pile of straw and feces has been pushed into the corner... and slept on. Guess how retching and foul it is in here. No, way worse.",
          "grid_x": 0,
          "grid_y": 65,
          "exits": {
            "go out": {
              "to_vnum": 782,
              "to_zone": "Swamp Mini-Quests - Great Ancestral Swamp",
