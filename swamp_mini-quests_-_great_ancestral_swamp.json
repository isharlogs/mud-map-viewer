        "778": {
          "vnum": 778,
          "name": "In the Swamp",
          "description": "A massive hardwood tree looms overhead, draping blankets of moss all around what looks to have once been a villager's home. Exposed lie the ruins of a stone building destroyed by a fire. Only way out is back north or northeast.",
          "grid_x": 0,
          "grid_y": 35,
          "exits": {
