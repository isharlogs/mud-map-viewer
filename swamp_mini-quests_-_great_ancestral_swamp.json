            {
              "name": "Thin needle snake",
              "description": "face to face with one.  Hundreds of hair-thin spines protrude from its back.",
              "unique": true
            }
          ]
        },
        "871": {
          "vnum": 871,
          "name": "Western Fork",
          "description": "As you move down this tunnel, the air takes on a warmer and an almost nauseating quality. The walls are oddly warm to the touch and feel smoother than those at the entrance. Clumps of vegetation line the base of the path. Though brown and brittle, the plants do actually seem to be growing.",
          "grid_x": -1,
          "grid_y": 0,
          "exits": {
            "e": {
              "to_vnum": 870,
              "to_zone": "Swamp Mini-Quests - Great Ancestral Swamp",
              "to_room_name": "Cave Fork",
              "direction": "e",
              "is_cross_zone": false,
              "is_portal": false
            },
            "sw": {
              "to_vnum": 872,
              "to_zone": "Swamp Mini-Quests - Great Ancestral Swamp",
              "to_room_name": "Poisonous Florae",
              "direction": "sw",
              "is_cross_zone": false,
