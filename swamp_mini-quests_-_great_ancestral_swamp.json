              "direction": "go out",
              "is_cross_zone": false,
              "is_portal": true
            }
          },
          "npcs": [
            {
              "name": "Luscious maiden",
              "description": "captivating, dainty, refreshing, entrancing, witty, seductive... She'll certainly warm you down to the very cockles of your heart.",
              "unique": true
            },
            {
              "name": "Tremendous pit troll",
              "description": "breath is worse than cardboard.",
              "unique": true
            }
          ]
        },
        "874": {
          "vnum": 874,
          "name": "The Graveyard",
          "description": "The narrow tunnel has opened up into a very large cavern. Rock formations hang from the ceiling and jut from the floor. With each step you take, you hear the sickening crack of breaking bones under your feet; they literally carpet the floor of the cavern. A heavy door is set on the wall to the northwest.",
          "grid_x": 1,
          "grid_y": 2,
