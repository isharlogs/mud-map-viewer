            }
          },
          "npcs": []
        },
        "872": {
          "vnum": 872,
          "name": "Poisonous Florae",
          "description": "The path ends here in a hazy room full of spores. The longer you remain here the more likely you are to become infected by whatever you're breathing. Between breaths and worrying about disease, you marvel at the plethora of plantlife growing here. Every single plant formation is uniquely warped and most look downright leprous. Some of the larger ones even look carnivorous.",
          "grid_x": -2,
          "grid_y": 1,
          "exits": {
            "ne": {
              "to_vnum": 871,
              "to_zone": "Swamp Mini-Quests - Great Ancestral Swamp",
              "to_room_name": "Western Fork",
              "direction": "ne",
              "is_cross_zone": false,
              "is_portal": false
            }
          },
          "npcs": []
        },
        "873": {
          "vnum": 873,
          "name": "Southeastern Fork",
          "description": "The air is thick, and smells older than anything you can imagine. In mild surprise, your nose detects a familiar scent; death. The floor is littered with small puddles of disgustingly murky water. In the dim light, you can just see that the entire surface of the eastern wall is covered with holes the size of your wrist.",
          "grid_x": 1,
          "grid_y": 1,
          "exits": {
            "nw": {
              "to_vnum": 870,
              "to_zone": "Swamp Mini-Quests - Great Ancestral Swamp",
