        "875": {
          "vnum": 875,
          "name": "Dead End",
          "description": "As you round the corner to the east, the path suddenly stops at a smooth, glossy rock wall. Pitted into the floor here is a small puddle of water. Though you can see the droplets of water falling from above, the darkness above you refuses to reflect any light. The only apparent exit is back west.",
          "grid_x": 0,
          "grid_y": 1,
          "exits": {
            "w": {
              "to_vnum": 870,
