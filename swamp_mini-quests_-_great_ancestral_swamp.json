        },
        "782": {
          "vnum": 782,
          "name": "Outside a Bone Hut",
          "description": "Millions of bones carpet the entire area and crunch noisily under your feet. The largest bones have been crudely fashioned into an enormous hut. If that doesn't interest you, you can try to climb down the mound.",
          "grid_x": 0,
          "grid_y": 50,
