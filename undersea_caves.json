        "2145": {
          "vnum": 2145,
          "name": "Tomb",
          "description": "This small, blank and rough walled chamber smells of old death. Two skeletons lay sprawled on the floor and a third is stretched out on a rough wooden cot. Various personal effects are scattered about, the door you came through is to the south.",
