        "2146": {
          "vnum": 2146,
          "name": "The Cave",
          "description": "You stand at the north end of a cave that extends into darkness to the south. The cave is large enough for comfortable travel but the floor is uneven and littered with chunks of stone. A narrow opening gapes on darkness to the west.",
