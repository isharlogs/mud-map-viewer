        "2140": {
          "vnum": 2140,
          "name": "The Cavern",
          "description": "Swells lap at the rocky ground as it slopes up out of the ocean and climbs to the south. The cavern seems alive with rustles and whispers as the ever- present sound of water in motion is echoed back from a thousand sources.",
